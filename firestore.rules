rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — own data only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rescue Crew — owner-only emergency contacts (public exposure is gated
    // server-side via the Admin SDK when the pet is marked lost; never read directly)
    // create: server-side only via Admin SDK (app/api/rescue-crew), so the
    //   per-owner contact cap can actually be enforced — a client-side check
    //   alone could be bypassed by writing to Firestore directly.
    match /users/{userId}/rescueCrew/{contactId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if false;
    }

    // Owners — own data only
    match /owners/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tags — public read (QR code scanners need this without auth)
    // create: server-side only via Firebase Admin SDK (tag import scripts)
    // update: authenticated users can claim an unclaimed tag or update their own
    //   Claim semantics: userId set + isActive false = claimed/draft (profile being filled)
    //                    isActive true = fully activated (public pet profile live)
    //   A tag without a userId field, or with userId == null, is unclaimed and may be
    //   claimed by any authenticated user. Once claimed, only that user may update it.
    match /tags/{code} {
      allow read: if true;
      allow create: if false;
      allow update: if request.auth != null && (
        !('userId' in resource.data) ||
        resource.data.userId == null ||
        resource.data.userId == request.auth.uid
      );
    }

    // Orders — written by Stripe webhook via Admin SDK (server-side)
    // Clients can only read their own orders
    match /orders/{orderId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow write: if false;
    }

    // Newsletter subscribers — server-side only via Admin SDK
    match /newsletter_subscribers/{docId} {
      allow read, write: if false;
    }
  }
}
