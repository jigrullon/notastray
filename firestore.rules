rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read and write their own documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow users to read and write their own owner profile (subscription, tags, etc.)
    match /owners/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tags - public read (QR code scanners need to see pet profiles), owner write
    match /tags/{code} {
      allow read: if true;
      allow create, update: if request.auth != null && (
        // Allow if tag is unassigned (first activation)
        resource == null || resource.data.userId == null ||
        // Allow if user owns the tag
        resource.data.userId == request.auth.uid
      );
    }

    // Orders - created by webhook (server-side), readable for order verification
    // NOTE: For development/testing - relaxed rules. Tighten for production.
    match /orders/{orderId} {
      allow create: if true;
      allow update: if true;
      allow read: if true;
    }
  }
}
