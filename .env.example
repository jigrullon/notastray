# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Stripe Configuration (for shop)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Optional: Email service for notifications
SENDGRID_API_KEY=your-sendgrid-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Google reCAPTCHA v2 (tag lookup bot protection)
# Create a v2 "I'm not a robot" Checkbox site at https://www.google.com/recaptcha/admin
# Leave both unset locally to skip CAPTCHA in dev mode.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Custom Email Verification
# EMAIL_VERIFICATION_SECRET signs verification tokens (HMAC-SHA256).
# Generate with: openssl rand -base64 32
# Server-only — NEVER prefix with NEXT_PUBLIC_ and never commit the real value.
EMAIL_VERIFICATION_SECRET=your_email_verification_secret
# NEXT_PUBLIC_APP_URL is the base URL used to build verification links.
# Build-time inlined by Next.js — set it in Vercel before the build runs.
NEXT_PUBLIC_APP_URL=https://notastray.com
